<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_doctor">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center mt-4">
                            <span t-field="doc.full_name"/>
                            <t t-if="doc.specialty_id">
                                - <span t-field="doc.specialty_id.name"/>
                            </t>
                        </h2>

                        <h3 class="mt-4">Visit History</h3>
                        <t t-set="visits" t-value="doc.env['hr.hospital.visit'].search([('doctor_id', '=', doc.id)], order='planned_date desc')"/>
                        <table class="table table-sm table-borderless mt-3">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Patient</th>
                                    <th>Status</th>
                                    <th>Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="visits" t-as="visit">
                                    <td>
                                        <span t-if="visit.actual_date" t-field="visit.actual_date"/>
                                        <span t-else="" t-field="visit.planned_date"/>
                                    </td>
                                    <td><span t-field="visit.patient_id.full_name"/></td>
                                    <td><span t-field="visit.state"/></td>
                                    <td><span t-field="visit.visit_type"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <h3 class="mt-4">Patients</h3>
                        <t t-set="patients" t-value="doc.env['hr.hospital.patient'].search([('personal_doctor_id', '=', doc.id)])"/>
                        <table class="table table-sm table-bordered mt-3">
                            <thead>
                                <tr>
                                    <th>Patient Name</th>
                                    <th>Gender</th>
                                    <th>Date of Birth</th>
                                    <th>Phone</th>
                                    <th>Current Visit Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="patients" t-as="patient">
                                    <td><span t-field="patient.full_name"/></td>
                                    <td class="text-capitalize"><span t-field="patient.gender"/></td>
                                    <td><span t-field="patient.birthday"/></td>
                                    <td><span t-field="patient.phone"/></td>

                                    <t t-set="last_visit" t-value="doc.env['hr.hospital.visit'].search([('patient_id', '=', patient.id), ('doctor_id', '=', doc.id)], order='planned_date desc', limit=1)"/>
                                    <t t-set="status_class" t-value="''"/>

                                    <t t-if="last_visit">
                                        <t t-if="last_visit.state == 'scheduled'"><t t-set="status_class" t-value="'bg-warning'"/></t>
                                        <t t-elif="last_visit.state == 'completed'"><t t-set="status_class" t-value="'bg-success text-white'"/></t>
                                        <t t-elif="last_visit.state in ['cancelled', 'no_show']"><t t-set="status_class" t-value="'bg-danger text-white'"/></t>
                                    </t>

                                    <td t-att-class="status_class">
                                        <span t-if="last_visit" t-field="last_visit.state"/>
                                        <span t-else="">No visits</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="footer text-center">
                        <div class="row border-top pt-2">
                            <div class="col-6 text-start">
                                Printed on: <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                            </div>
                            <div class="col-6 text-end">
                                City: <span t-field="doc.env.company.city"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>