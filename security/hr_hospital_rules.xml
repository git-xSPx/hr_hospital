<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="rule_hr_hospital_visit_patient" model="ir.rule">
            <field name="name">Patient: see own visits</field>
            <field name="model_id" ref="model_hr_hospital_visit"/>
            <field name="groups" eval="[(4, ref('hr_hospital.group_hr_hospital_patient'))]"/>
            <field name="domain_force">[('patient_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_hr_hospital_visit_intern" model="ir.rule">
            <field name="name">Intern: see and edit own visits</field>
            <field name="model_id" ref="model_hr_hospital_visit"/>
            <field name="groups" eval="[(4, ref('hr_hospital.group_hr_hospital_intern'))]"/>
            <field name="domain_force">[('doctor_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_hr_hospital_visit_doctor" model="ir.rule">
            <field name="name">Doctor: see and edit own and intern visits</field>
            <field name="model_id" ref="model_hr_hospital_visit"/>
            <field name="groups" eval="[(4, ref('hr_hospital.group_hr_hospital_doctor'))]"/>
            <field name="domain_force">['|', ('doctor_id.user_id', '=', user.id), ('mentor_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_hr_hospital_visit_manager" model="ir.rule">
            <field name="name">Manager: see all visits</field>
            <field name="model_id" ref="model_hr_hospital_visit"/>
            <field name="groups" eval="[(4, ref('hr_hospital.group_hr_hospital_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_hr_hospital_visit_admin" model="ir.rule">
            <field name="name">Admin: full access to visits</field>
            <field name="model_id" ref="model_hr_hospital_visit"/>
            <field name="groups" eval="[(4, ref('hr_hospital.group_hr_hospital_administrator'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

    </data>
</odoo>